generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id             String         @id @default(uuid())
  username       String
  name           String
  email          String         @unique
  phone          String?
  role           String
  barcode        String?        @unique
  password       String
  created_at     DateTime       @default(now())
  approved       Boolean        @default(false)
  email_verified Boolean        @default(false)
  Anomaly        Anomaly[]
  AuditLog       AuditLog[]
  LoginAttempt   LoginAttempt[]
  Notification   Notification[]
  OTP            OTP[]
}

model Barcode {
  id         String   @id @default(uuid())
  code       String   @unique
  student_id String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  student    Student  @relation(fields: [student_id], references: [id])
}

model AttendanceRecord {
  id               String    @id @default(uuid())
  barcode          String
  check_in         DateTime
  check_out        DateTime?
  date             DateTime
  duration_minutes Int?
  status           String
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  student_id       String
  student          Student   @relation(fields: [student_id], references: [id])
}

model OTP {
  id         String   @id @default(uuid())
  user_id    String
  code       String
  used       Boolean  @default(false)
  expiresAt  DateTime
  created_at DateTime @default(now())
  user       Profile  @relation(fields: [user_id], references: [id])
}

model Anomaly {
  id          String   @id @default(uuid())
  type        String
  severity    String
  description String
  dismissed   Boolean  @default(false)
  detected_at DateTime @default(now())
  score       Float?
  user_id     String
  user        Profile  @relation(fields: [user_id], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  ip_address String?
  created_at DateTime @default(now())
  details    Json?
  entity     String
  entity_id  String?
  user_id    String?
  user       Profile? @relation(fields: [user_id], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  user_id    String?
  user       Profile? @relation(fields: [user_id], references: [id])
}

model LoginAttempt {
  id            String    @id @default(uuid())
  attempt_count Int       @default(0)
  locked_until  DateTime?
  last_attempt  DateTime?
  user_id       String
  user          Profile   @relation(fields: [user_id], references: [id])
}

model Student {
  id          String             @id @default(uuid())
  studentId   String             @unique
  name        String
  email       String?            @unique
  phone       String?
  qrCode      String             @unique
  department  String?
  year        String?
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  attendances AttendanceRecord[]
  Barcode     Barcode[]
}
